% AsymVerify: purple recolor of the Gemini color theme (white header, ACL register)
% Based on gemini's beamercolorthemegemini.sty (anishathalye/gemini, MIT).

\definecolor{purpleDeep}{HTML}{3B2A6B}
\definecolor{purpleBrand}{HTML}{5B3C9E}
\definecolor{violetA}{HTML}{7E5BC2}
\definecolor{lavender}{HTML}{ECE7F7}
\definecolor{lavenderTwo}{HTML}{DCD2F0}
\definecolor{inkA}{HTML}{1F1A2E}
\definecolor{slateA}{HTML}{6E6880}
\definecolor{passOne}{HTML}{3F4DA8}
\definecolor{passTwo}{HTML}{D24B7A}
\definecolor{passThree}{HTML}{2E9E6B}

% Basic
\setbeamercolor{palette primary}{fg=inkA,bg=white}
\setbeamercolor{structure}{fg=purpleBrand}

% Headline (white header so dark logos read; purple title + rule)
\setbeamercolor{headline}{fg=inkA,bg=white}
\setbeamercolor{headline title}{fg=purpleDeep,bg=white}
\setbeamercolor{headline author}{fg=inkA,bg=white}
\setbeamercolor{headline institute}{fg=slateA,bg=white}
\setbeamercolor{headline rule}{bg=purpleDeep}

% Footer: deep-purple band with white text
\setbeamercolor{footer}{fg=white,bg=purpleDeep}

% Block (white body, purple title, purple separator rule under the title)
\setbeamercolor{block title}{fg=purpleDeep,bg=white}
\setbeamercolor{block separator}{bg=purpleBrand}
\setbeamercolor{block body}{fg=inkA,bg=white}

% Alert block (used sparingly for one highlighted callout)
\setbeamercolor{block title alerted}{fg=white,bg=purpleBrand}
\setbeamercolor{block separator alerted}{bg=purpleDeep}
\setbeamercolor{block body alerted}{fg=inkA,bg=lavender}

% Example block
\setbeamercolor{block title example}{fg=purpleDeep,bg=lavender}
\setbeamercolor{block separator example}{bg=purpleBrand}
\setbeamercolor{block body example}{fg=inkA,bg=lavender}

% Heading (sub-section inside a block)
\setbeamercolor{heading}{fg=purpleBrand}

% Itemize
\setbeamercolor{item}{fg=purpleBrand}

% Bibliography
\setbeamercolor{bibliography item}{fg=inkA}
\setbeamercolor{bibliography entry author}{fg=inkA}
\setbeamercolor{bibliography entry title}{fg=inkA}
\setbeamercolor{bibliography entry location}{fg=inkA}
\setbeamercolor{bibliography entry note}{fg=inkA}
